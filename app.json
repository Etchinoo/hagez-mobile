{
  "expo": {
    "name": "Hagez",
    "slug": "hagez",
    "scheme": "hagez",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logos/fav_icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logos/fav_icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "eg.reservr.consumer",
      "buildNumber": "1",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to upload business photos.",
        "NSPhotoLibraryUsageDescription": "Used to select profile and booking photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logos/fav_icon.png",
        "backgroundColor": "#F5F5F5"
      },
      "package": "eg.reservr.consumer",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/logos/fav_icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/logos/fav_icon.png",
          "color": "#0F2044",
          "sounds": []
        }
      ],
      "expo-font",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-google-signin/google-signin"
    ],
    "newArchEnabled": true,
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "fa6fd7a4-ffe4-47be-8669-16cef1c5f3a6"
      }
    },
    "owner": "etchinoo"
  }
}
