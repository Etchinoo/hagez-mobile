# ============================================================
# HAGEZ MOBILE — Environment Variables
# Copy to .env and fill in for local development.
# All EXPO_PUBLIC_* vars are inlined into the JS bundle at build time.
# ============================================================

# API base URL (Fastify backend)
# Local dev (Android emulator): http://10.0.2.2:3000/v1
# Local dev (iOS simulator):    http://localhost:3000/v1
# Local dev (physical device):  http://<your-LAN-IP>:3000/v1
# Staging:                      https://api-staging.reservr.eg/v1
# Production:                   https://api.reservr.eg/v1
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/v1

# Google Maps API key (used for map views)
EXPO_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_key
